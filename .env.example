# ── Postgres / TimescaleDB ───────────────────────────────────────────────────
POSTGRES_USER=execrelay
POSTGRES_PASSWORD=execrelay_dev_password
POSTGRES_DB=execrelay

# ── NATS ──────────────────────────────────────────────────────────────────────
# Credentials used by the NATS server and all client services.
NATS_USER=execrelay
NATS_PASS=execrelay_nats_dev

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=execrelay
MINIO_ROOT_PASSWORD=execrelay_dev_password

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_BACKEND_STORE_URI=postgresql://execrelay:execrelay_dev_password@postgres:5432/execrelay
MLFLOW_ARTIFACT_ROOT=s3://execrelay-mlflow/

# ── Ingress ───────────────────────────────────────────────────────────────────
# Format: licenseID:alertSecret:hmacSecret:instanceID[:platform]
# Multiple entries separated by semicolons. Platform defaults to mt5.
# Example: 60123456789:my-alert-secret:my-hmac-secret:mt5-a:mt5
EXECRELAY_LICENSES=
# Optional: path to a file containing the same format as EXECRELAY_LICENSES.
# When set, takes precedence over EXECRELAY_LICENSES. Send SIGHUP to reload.
EXECRELAY_LICENSES_FILE=
INGRESS_REGION=iad
# Reject webhooks whose X-ExecRelay-Timestamp header is older than this (seconds). 0 = disabled.
WEBHOOK_TIMESTAMP_WINDOW_SECS=30
# Max webhook requests per minute per source IP. 0 = disabled.
WEBHOOK_RATE_LIMIT=60

# ── Bridge ────────────────────────────────────────────────────────────────────
BRIDGE_REGION=iad
# Shared secret EAs must present in the register message. Required in production.
BRIDGE_AUTH_TOKEN=change-this-in-production

# ── DXTrade adapter ──────────────────────────────────────────────────────────
# Format: instanceID:host:username:password:account
# Multiple entries separated by semicolons.
# Example: dxt-a:demo.dxtrade.com:trader@example.com:secret:ACC123456
DXTRADE_INSTANCES=

# ── Portal API ────────────────────────────────────────────────────────────────
# Change this before any non-local deployment.
JWT_SECRET=change-this-in-production
# Comma-separated list of allowed CORS origins. Use * only for local dev.
PORTAL_ALLOWED_ORIGINS=https://yourportal.example.com

# ── Portal Web ───────────────────────────────────────────────────────────────
# URL of the portal-api as seen from the portal-web container.
# In Docker Compose this resolves via the service name.
PORTAL_API_URL=http://portal-api:8080

# Internal service URL that portal-api uses to fire test signals.
INGRESS_URL=http://ingress:8080

# ── Tasks ─────────────────────────────────────────────────────────────────────
# How long to retain signals and fills (days).
RETENTION_DAYS=90
# How many seconds after a signal is accepted before a missing fill is flagged.
FILL_TIMEOUT_SECS=30

{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests"
  ],
  "dependencyDashboard": true,
  "enabledManagers": [
    "docker-compose",
    "dockerfile",
    "github-actions",
    "gomod",
    "npm",
    "pep621"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": true
    }
  ]
}
